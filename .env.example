# Map basemap style. The default below (MapLibre demotiles) is a KEYLESS
# placeholder with only low-zoom world data — it shows continents, not streets.
# For a real city-level basemap, create a free MapTiler key
# (https://cloud.maptiler.com) and use, for example:
#   EXPO_PUBLIC_MAP_STYLE_URL=https://api.maptiler.com/maps/streets-v2/style.json?key=YOUR_MAPTILER_KEY
EXPO_PUBLIC_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json

# Optional backend. Leave these unset to run fully local (in-memory) mode.
# If set, the app uses Supabase — enable "anonymous sign-ins" on the project.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
