# MapTiler key for selectable Streets / Outdoor / Dark map skins.
# Create a free key at https://cloud.maptiler.com.
EXPO_PUBLIC_MAPTILER_KEY=your-maptiler-key

# Optional keyless/custom fallback used when EXPO_PUBLIC_MAPTILER_KEY is unset.
EXPO_PUBLIC_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json

# Optional backend. Leave these unset to run fully local (in-memory) mode.
# If set, the app uses Supabase — enable "anonymous sign-ins" on the project.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
